{
  "name": "schuss",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "map": "esbuild tools/coursemap.ts --bundle --platform=node --format=esm --outfile=node_modules/.design/coursemap.mjs --log-level=silent && node node_modules/.design/coursemap.mjs",
    "ride": "esbuild tools/ride.ts --bundle --platform=node --format=esm --outfile=node_modules/.design/ride.mjs --log-level=silent && node node_modules/.design/ride.mjs"
  },
  "lint-staged": {
    "**/*.ts": [
      "prettier --write"
    ],
    "**/*.{json,md,yaml,yml,css,html}": "prettier --write"
  },
  "dependencies": {
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^3.0.0"
  }
}
